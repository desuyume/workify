{
  "name": "workify",
  "private": true,
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma",
    "seed": "tsx packages/database/src/seed.ts"
  },
  "scripts": {
    "start": "turbo run start",
    
    "build": "bun run build:packages && bun run build:apps",
    "build:local": "bun run build:packages && bun run db:setup && bun run build:apps",
    "build:packages": "turbo run build --filter=shared --filter=ui --filter=database",
    "build:apps": "turbo run build --filter=frontend --filter=backend",
    "build:full": "bun run build && bun run db:setup",
    "build:frontend": "turbo run build --filter=frontend",
    "build:backend": "turbo run build --filter=backend",
    
    "dev": "turbo run dev & bun run prisma:studio",
    "predev": "bun run db:setup",
    
    "db:generate": "cd packages/database && bun run db:generate",
    "db:setup": "cd packages/database && bun run db:setup",
    "db:migrate": "cd packages/database && bun run db:migrate",
    "db:migrate:dev": "cd packages/database && bun run db:migrate:dev",
    "db:seed": "cd packages/database && bun run db:seed",
    "db:prepare": "cd packages/database && bun run db:prepare",
    "prisma:studio": "cd packages/database && bun run studio",
    
    "format": "turbo run format",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "author": "desuyume <https://t.me/desuyume>",
  "devDependencies": {
    "@desuyume/prettier": "^1.0.0",
    "@workify/eslint-config": "workspace:*",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tsx": "^4.20.6",
    "turbo": "^1.13.4"
  },
  "packageManager": "bun@1.3.3",
  "dependencies": {
    "node-jose-tools": "^2.0.4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}